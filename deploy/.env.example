# Base private dashboard deployment
VIBEGUARD_IMAGE=vibeguard:local
VIBEGUARD_DASHBOARD_BIND=127.0.0.1
VIBEGUARD_DASHBOARD_PORT=8787
VIBEGUARD_DASHBOARD_TOKEN=replace-with-a-long-random-administrator-token
VIBEGUARD_FINDINGS_INGEST_TOKEN=replace-with-a-distinct-long-random-ci-token

# Optional anonymous false-positive collector; keep false unless clients intentionally opt in.
VIBEGUARD_TELEMETRY_COLLECTION=false
VIBEGUARD_TELEMETRY_MAX_EVENTS_PER_MINUTE=60

# Required only with compose.oidc.yaml behind an HTTPS reverse proxy
VIBEGUARD_PUBLIC_URL=https://guard.example.com
VIBEGUARD_OIDC_ISSUER=https://id.example.com
VIBEGUARD_OIDC_CLIENT_ID=vibeguard-dashboard
VIBEGUARD_OIDC_CLIENT_SECRET=replace-with-provider-secret
VIBEGUARD_OIDC_SESSION_SECRET=replace-with-at-least-32-random-characters
VIBEGUARD_OIDC_ROLE_CLAIM=groups
VIBEGUARD_OIDC_ANALYST_ROLE=security-reviewers
VIBEGUARD_OIDC_ADMIN_ROLE=platform-admins
