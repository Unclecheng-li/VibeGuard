{
  "name": "vibeguard",
  "displayName": "VibeGuard",
  "description": "AI-generated code security scanner for hallucinated packages, hardcoded secrets, unsafe configs, and common AI coding mistakes.",
  "version": "0.1.0",
  "publisher": "vibeguard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vibeguard/vibeguard.git"
  },
  "private": true,
  "type": "commonjs",
  "main": "./dist/extension.js",
  "bin": {
    "vibeguard": "./dist/cli.js",
    "vibeguard-lsp": "./dist/lspServer.js"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Security"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:vibeguard.scanCurrentFile",
    "onCommand:vibeguard.scanWorkspace",
    "onCommand:vibeguard.syncPackageCache",
    "onCommand:vibeguard.exportDashboard",
    "onCommand:vibeguard.setLlmApiKey",
    "onCommand:vibeguard.deleteLlmApiKey",
    "onCommand:vibeguard.showLlmStatus",
    "onCommand:vibeguard.applyFix",
    "onCommand:vibeguard.applyAllSafeFixes",
    "onView:vibeguardFindings"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vibeguard.scanCurrentFile",
        "title": "VibeGuard: Scan Current File"
      },
      {
        "command": "vibeguard.scanWorkspace",
        "title": "VibeGuard: Scan Workspace"
      },
      {
        "command": "vibeguard.clearFindings",
        "title": "VibeGuard: Clear Findings"
      },
      {
        "command": "vibeguard.openReport",
        "title": "VibeGuard: Open Findings Report"
      },
      {
        "command": "vibeguard.exportDashboard",
        "title": "VibeGuard: Export Findings Dashboard"
      },
      {
        "command": "vibeguard.openIgnoreRules",
        "title": "VibeGuard: Open Ignore Rules"
      },
      {
        "command": "vibeguard.syncPackageCache",
        "title": "VibeGuard: Sync Package Cache"
      },
      {
        "command": "vibeguard.setLlmApiKey",
        "title": "VibeGuard: Set LLM API Key"
      },
      {
        "command": "vibeguard.deleteLlmApiKey",
        "title": "VibeGuard: Delete LLM API Key"
      },
      {
        "command": "vibeguard.showLlmStatus",
        "title": "VibeGuard: Show LLM Status"
      },
      {
        "command": "vibeguard.ignoreFinding",
        "title": "VibeGuard: Ignore This Finding"
      },
      {
        "command": "vibeguard.ignoreRuleInFile",
        "title": "VibeGuard: Ignore Rule in This File"
      },
      {
        "command": "vibeguard.ignoreRuleGlobally",
        "title": "VibeGuard: Ignore Rule Globally"
      },
      {
        "command": "vibeguard.ignorePackage",
        "title": "VibeGuard: Ignore Package"
      },
      {
        "command": "vibeguard.applyFix",
        "title": "VibeGuard: Apply Fix"
      },
      {
        "command": "vibeguard.applyAllSafeFixes",
        "title": "VibeGuard: Apply All Safe Fixes in Current File"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "vibeguard.ignoreFinding",
          "when": "view == vibeguardFindings && viewItem == vibeguardFinding",
          "group": "inline"
        },
        {
          "command": "vibeguard.ignoreRuleInFile",
          "when": "view == vibeguardFindings && viewItem == vibeguardFinding",
          "group": "navigation"
        },
        {
          "command": "vibeguard.ignoreRuleGlobally",
          "when": "view == vibeguardFindings && viewItem == vibeguardFinding",
          "group": "navigation"
        },
        {
          "command": "vibeguard.ignorePackage",
          "when": "view == vibeguardFindings && viewItem == vibeguardFinding",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "VibeGuard",
      "properties": {
        "vibeguard.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable VibeGuard security scanning."
        },
        "vibeguard.scanOnChange": {
          "type": "boolean",
          "default": true,
          "description": "Scan supported documents shortly after edits."
        },
        "vibeguard.scanOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Scan supported documents when they are saved."
        },
        "vibeguard.packageVerification": {
          "type": "string",
          "enum": [
            "seed",
            "remote",
            "off"
          ],
          "default": "seed",
          "description": "How VibeGuard verifies package names. Seed mode is instant and offline; remote mode also checks npm/PyPI registries."
        },
        "vibeguard.configPath": {
          "type": "string",
          "default": "",
          "description": "Path to config.json. Defaults to ~/.vibeguard/config.json."
        },
        "vibeguard.autoSyncPackageCache": {
          "type": "boolean",
          "default": true,
          "description": "Automatically sync the local package-name cache in the background when VSCode starts."
        },
        "vibeguard.packageCacheLanguages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "npm",
              "pypi",
              "cargo",
              "gomod",
              "maven"
            ]
          },
          "default": [
            "npm",
            "pypi"
          ],
          "description": "Package registries to keep in the local package-name cache. Explicit VSCode settings override config.json package_cache.languages."
        },
        "vibeguard.packageCacheUpdateInterval": {
          "type": "string",
          "enum": [
            "daily",
            "weekly"
          ],
          "default": "daily",
          "description": "How often VSCode background sync refreshes package-name indexes."
        },
        "vibeguard.packageCacheLightweightMode": {
          "type": "boolean",
          "default": true,
          "description": "Use lightweight partial package-name indexes for faster cold starts."
        },
        "vibeguard.enableL2": {
          "type": "boolean",
          "default": true,
          "description": "Enable lightweight asynchronous SAST rules for SQL injection, XSS, SSRF, path traversal, unsafe deserialization, and command injection."
        },
        "vibeguard.l2DebounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 0,
          "maximum": 30000,
          "description": "Delay in milliseconds before VSCode runs L2 SAST analysis after edits. L1 diagnostics still run immediately."
        },
        "vibeguard.enableL3": {
          "type": "boolean",
          "default": false,
          "description": "Enable L3 semantic security checks. When an LLM provider and credential are available, VibeGuard uses them; otherwise it falls back to local endpoint heuristics."
        },
        "vibeguard.l3DebounceMs": {
          "type": "number",
          "default": 2000,
          "minimum": 0,
          "maximum": 30000,
          "description": "Delay in milliseconds before VSCode runs L3 semantic analysis after edits. Saves and manual scans run L3 immediately."
        },
        "vibeguard.llmProvider": {
          "type": "string",
          "enum": [
            "deepseek",
            "claude",
            "openai",
            "local"
          ],
          "default": "deepseek",
          "description": "LLM provider for VibeGuard L3 semantic analysis. API keys are stored with VSCode SecretStorage or read from environment variables."
        },
        "vibeguard.llmModel": {
          "type": "string",
          "default": "",
          "description": "Optional model override for L3 semantic analysis."
        },
        "vibeguard.llmBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Optional provider base URL override for L3 semantic analysis, useful for compatible gateways or local Ollama hosts."
        },
        "vibeguard.dedupWithExistingTools": {
          "type": "boolean",
          "default": true,
          "description": "Dismiss duplicate L2 findings when nearby SonarQube, Snyk, Semgrep, or CodeQL annotations already cover the same issue."
        },
        "vibeguard.storeFindings": {
          "type": "boolean",
          "default": true,
          "description": "Store scan runs and findings in a local SQLite database."
        },
        "vibeguard.findingsDbPath": {
          "type": "string",
          "default": "",
          "description": "Path to findings.db. Defaults to ~/.vibeguard/findings.db."
        },
        "vibeguard.ignoredFindings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Exact finding IDs to dismiss in addition to config.json ignored_findings."
        },
        "vibeguard.customRules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Paths to custom VibeGuard YAML rule files. Relative paths resolve from the workspace folder."
        },
        "vibeguard.showCriticalPopups": {
          "type": "boolean",
          "default": true,
          "description": "Show warning popups for newly detected critical findings."
        },
        "vibeguard.ignoreRulesPath": {
          "type": "string",
          "default": "",
          "description": "Path to ignore-rules.yml. Defaults to ~/.vibeguard/ignore-rules.yml."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vibeguard",
          "title": "VibeGuard",
          "icon": "media/vibeguard.svg"
        }
      ]
    },
    "views": {
      "vibeguard": [
        {
          "id": "vibeguardFindings",
          "name": "Findings"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "build": "node scripts/build.js",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test \"out/tests/**/*.test.js\"",
    "lint": "tsc --noEmit -p ./",
    "vscode:prepublish": "npm run build",
    "package:vsix": "vsce package --out vibeguard-0.1.0.vsix"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.92.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "minimatch": "^10.2.5",
    "tree-sitter-wasms": "^0.1.13",
    "vscode-languageserver": "^10.1.0",
    "vscode-languageserver-textdocument": "^1.0.12",
    "web-tree-sitter": "^0.20.8",
    "yaml": "^2.9.0"
  }
}
